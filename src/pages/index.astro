---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../lib/site';
import "../styles/blog.css";

import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const tools = await getCollection('tools');
const products = await getCollection('product');

/* LATEST ARTICLES */

const latestPosts = [...posts]
  .sort(
    (a, b) =>
      new Date(b.data.date) -
      new Date(a.data.date)
  )
  .slice(0, 3);

/* POPULAR ARTICLES */

const popularPosts =
  posts.filter(post => post.data.popular).length > 0
    ? posts
        .filter(post => post.data.popular)
        .slice(0, 3)
    : posts.slice(0, 3);

/* POPULAR TOOLS */

const popularTools =
  tools.filter(tool => tool.data.popular).length > 0
    ? tools
        .filter(tool => tool.data.popular)
        .slice(0, 3)
    : tools.slice(0, 3);

/* POPULAR PRODUCTS */

const popularProducts =
  products.filter(product => product.data.popular).length > 0
    ? products
        .filter(product => product.data.popular)
        .slice(0, 3)
    : products.slice(0, 3);

const pageTitle =
  'Robopragma | Website Resmi Platform AI Indonesia';

const pageDescription =
  'Website resmi Robopragma. Akses platform AI Indonesia untuk produktivitas digital, pembuatan konten, dan solusi otomatisasi modern.';
