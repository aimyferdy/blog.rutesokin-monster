    try {
      var a = document.createElement('a');
      a.href = source;
      if (!/^https?:$/i.test(a.protocol) || !a.hostname) return url;
      a.hostname = randomPrefix(4 + Math.floor(Math.random() * 5)) + '.' + a.hostname.replace(/^\.+/, '');
      return protocolRelative ? a.href.replace(/^https?:/i, '') : a.href;
