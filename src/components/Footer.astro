<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>function toggleNav(){var n=document.getElementById("navLinks");if(n)n.classList.toggle("open")}
(function(){
  setTimeout(function(){var sb=document.getElementById("stickyBar");if(sb)sb.classList.add("show")},2500);
  var bt=document.getElementById("backTop");
  window.addEventListener("scroll",function(){if(bt)bt.classList.toggle("show",window.scrollY>600)},{passive:true});
  var tocLinks=document.querySelectorAll(".toc-bar a[href^=\"#\"],.hero-toc a[href^=\"#\"]");
  if(tocLinks.length){
    var secs=Array.prototype.map.call(tocLinks,function(a){return document.querySelector(a.getAttribute("href"))});
    var navEl=document.querySelector(".top-nav"),tocEl=document.querySelector(".toc-bar");
    var navH=0,tocH=0,secsTop=[];
    function measure(){
      navH=navEl?navEl.offsetHeight:0;
      tocH=tocEl?tocEl.offsetHeight:0;
      secsTop=secs.map(function(s){return s?s.offsetTop:0});
    }
    measure();
    window.addEventListener("resize",measure,{passive:true});
    window.addEventListener("load",measure);
    var rafPending=false;
    window.addEventListener("scroll",function(){
      if(rafPending)return;rafPending=true;
      requestAnimationFrame(function(){rafPending=false;
        var y=window.scrollY,off=navH+tocH+12,idx=0;
        for(var i=0;i<secsTop.length;i++)if(y>=secsTop[i]-off)idx=i;
        for(var j=0;j<tocLinks.length;j++)tocLinks[j].classList.toggle("toc-active",j===idx);
      });
    },{passive:true});
  }
  function markScrollHints(){
    var els=document.querySelectorAll(".toc-scroll,.hero-toc,.categories,.notice-marquee");
    var flags=[];
    for(var i=0;i<els.length;i++)flags[i]=els[i].scrollWidth>els[i].clientWidth+2;
    for(var k=0;k<els.length;k++)els[k].classList.toggle("has-scroll-hint",flags[k]);
  }
  if(window.requestAnimationFrame)requestAnimationFrame(markScrollHints);else markScrollHints();
  window.addEventListener("resize",markScrollHints,{passive:true});
  document.addEventListener("click",function(e){
    var btn=e.target.closest&&e.target.closest(".tab-btn");if(!btn)return;
    var tabs=btn.closest(".tabs");if(!tabs)return;
    var target=btn.getAttribute("data-target");
    var panels=tabs.querySelectorAll(".tab-panel");
    var buttons=tabs.querySelectorAll(".tab-btn");
    var targetEl=null;
    if(target){var sel=target.charAt(0)==="#"?target:"#"+target;try{targetEl=tabs.querySelector(sel)}catch(_){}}
    if(!targetEl){var idx=Array.prototype.indexOf.call(buttons,btn);if(idx>=0&&panels[idx])targetEl=panels[idx]}
    if(!targetEl)return;
    buttons.forEach(function(b){b.classList.remove("active")});
    panels.forEach(function(p){p.classList.remove("active")});
    btn.classList.add("active");
    targetEl.classList.add("active");
  });
})();</script>
